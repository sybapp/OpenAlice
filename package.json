{
  "name": "open-alice",
  "version": "1.0.0",
  "description": "File-based trading agent engine",
  "type": "module",
  "scripts": {
    "build:opentypebb": "cd packages/opentypebb && pnpm build",
    "dev": "pnpm build:opentypebb && tsx src/main.ts",
    "dev:ui": "cd ui && pnpm dev",
    "build": "pnpm build:ui && pnpm build:backend",
    "install:ui": "cd ui && pnpm install --frozen-lockfile",
    "build:ui": "cd ui && pnpm build",
    "build:backend": "pnpm build:opentypebb && tsup src/main.ts --format esm --dts",
    "test": "pnpm build:opentypebb && vitest run",
    "test:coverage": "pnpm build:opentypebb && vitest run --coverage",
    "test:ui": "cd ui && pnpm test",
    "test:watch": "vitest"
  },
  "keywords": [
    "trading",
    "ai-agent",
    "crypto",
    "securities",
    "file-driven"
  ],
  "author": "Open Alice Contributors",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TraderAlice/OpenAlice.git"
  },
  "homepage": "https://traderalice.com",
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.44",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/openai": "^3.0.30",
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "@grammyjs/auto-retry": "^2.0.2",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "ai": "^6.0.86",
    "ccxt": "^4.5.38",
    "decimal.js": "^10.6.0",
    "express": "^5.2.1",
    "grammy": "^1.40.0",
    "hono": "^4.12.5",
    "opentypebb": "workspace:*",
    "pino": "^10.3.1",
    "undici": "^7.22.0",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@vitest/coverage-v8": "4.0.18",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ccxt",
      "esbuild"
    ]
  }
}
